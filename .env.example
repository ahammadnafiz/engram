# Engram Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# PostgreSQL Settings
# =============================================================================
POSTGRES_PORT=5432
POSTGRES_USER=engram
POSTGRES_PASSWORD=engram_secret
POSTGRES_DB=engram

# =============================================================================
# Engram Settings
# =============================================================================
# Database connection (auto-generated by docker-setup.sh)
ENGRAM_DATABASE_URL=postgresql://engram:engram_secret@localhost:5432/engram

# Embedding Provider: "openai" or "sentence-transformers"
EMBEDDING_PROVIDER=openai

# OpenAI API Key (required if using openai provider)
# OPENAI_API_KEY=sk-your-key-here

# Embedding Model
# For OpenAI: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
# For Sentence Transformers: all-MiniLM-L6-v2, all-mpnet-base-v2
ENGRAM_EMBEDDING_MODEL=text-embedding-3-small
ENGRAM_EMBEDDING_DIMENSION=1536

# =============================================================================
# Search Settings
# =============================================================================
# Hybrid search weights (must sum to 1.0)
ENGRAM_WEIGHT_SEMANTIC=0.40
ENGRAM_WEIGHT_KEYWORD=0.20
ENGRAM_WEIGHT_DECAY=0.25
ENGRAM_WEIGHT_IMPORTANCE=0.15

# Decay rate per hour (higher = slower decay)
ENGRAM_DECAY_RATE=0.995

# =============================================================================
# Performance Settings
# =============================================================================
# Connection pool size
ENGRAM_MIN_POOL_SIZE=5
ENGRAM_MAX_POOL_SIZE=20

# Embedding cache size (0 to disable)
ENGRAM_EMBEDDING_CACHE_SIZE=1000

# Embedding batch size
ENGRAM_EMBEDDING_BATCH_SIZE=100

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
ENGRAM_LOG_SQL_QUERIES=false

# =============================================================================
# pgAdmin (Optional)
# =============================================================================
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@engram.local
PGADMIN_PASSWORD=admin
